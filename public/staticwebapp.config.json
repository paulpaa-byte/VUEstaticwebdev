{
  "routes": [
    {
      "route": "/login",
      "redirect": "/.auth/login/aad?post_login_redirect_uri=.referrer",
      "statusCode": 302
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout?post_logout_redirect_uri=/",
      "statusCode": 302
    },
    {
      "route": "/profile*",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/enrollments",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/enrollments/save",
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/courses/save",
      "allowedRoles": [
        "administrator"
      ]
    },
    {
      "route": "/api/courses/delete/*",
      "allowedRoles": [
        "administrator"
      ]
    },
    {
      "route": "/api/assets/upload-url",
      "allowedRoles": [
        "administrator"
      ]
    },
    {
      "route": "/admin*",
      "allowedRoles": [
        "administrator"
      ]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "platform": {
    "apiRuntime": "node:20"
  },
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/6d065164-364e-49dd-ab0f-da1750b40f97/v2.0",
          "clientIdSettingName": "AZURE_CLIENT_ID",
          "clientSecretSettingName": "AZURE_CLIENT_SECRET"
        }
      }
    }
  }
}